<h1 class="text-2xl font-bold mb-4">New Gallery</h1>

<%= form_with model: @gallery, local: true do |form| %>
  <div class="mb-4">
    <%= form.label :title %>
    <%= form.text_field :title, class: "border p-2 w-full" %>
  </div>

  <div class="mb-4">
    <%= form.label :description %>
    <%= form.text_area :description, class: "border p-2 w-full" %>
  </div>

  <%= form.submit "Create Gallery", class: "bg-blue-600 text-white px-4 py-2 rounded" %>
<% end %>