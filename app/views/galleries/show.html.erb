<h1 class="text-3xl font-bold mb-2"><%= @gallery.title %></h1>
<p class="text-gray-700 mb-6"><%= @gallery.description %></p>

<% if @gallery.user == current_user %>
  <div class="flex items-center gap-3 mb-8">
    <%= link_to "Edit",
        edit_gallery_path(@gallery),
        class: "bg-yellow-500 hover:bg-yellow-600 text-white px-3 py-1 rounded" %>

    <%= button_to "Delete",
        gallery_path(@gallery),
        method: :delete,
        data: { confirm: "Are you sure?" },
        class: "bg-red-600 hover:bg-red-700 text-white px-3 py-1 rounded" %>

    <%= link_to "Upload Photo",
        new_gallery_photo_path(@gallery),
        class: "bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded" %>
  </div>
<% end %>

<h2 class="text-2xl font-semibold mb-4 border-b pb-2">Photos</h2>

<% if @gallery.photos.any? %>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
    <% @gallery.photos.each do |photo| %>
      <div class="bg-white border rounded-lg shadow-sm p-3">
        <% if photo.image.attached? %>
          <%= image_tag photo.image.variant(resize_to_limit: [300, 300]).processed,
              class: "rounded mb-3 w-full object-cover" %>
        <% end %>

        <p class="text-gray-700 mb-3"><%= photo.caption %></p>

        <% if @gallery.user == current_user %>
          <%= button_to "Delete Photo",
                gallery_photo_path(@gallery, photo),
                method: :delete,
                data: { confirm: "Are you sure you want to delete this photo?" },
                class: "bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded text-sm w-full" %>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-gray-500">No photos uploaded yet.</p>
<% end %>