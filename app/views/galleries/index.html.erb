<h1 class="text-3xl font-bold mb-6">Galleries</h1>

<% if user_signed_in? %>
  <%= link_to "New Gallery", new_gallery_path, class: "bg-blue-600 text-white px-4 py-2 rounded" %>
<% end %>

<div class="mt-6 space-y-4">
  <% @galleries.each do |gallery| %>
    <div class="border p-4 rounded">
      <h2 class="text-xl font-semibold">
        <%= link_to gallery.title, gallery %>
      </h2>
      <p class="text-gray-600"><%= gallery.description %></p>
      <p class="text-sm text-gray-400">By <%= gallery.user.email %></p>
    </div>
  <% end %>
</div>
