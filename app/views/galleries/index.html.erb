<h1 class="text-3xl font-bold mb-6">Galleries</h1>
<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
  <% @galleries.each do |gallery| %>
    <% next if gallery.photos.empty? %>

    <div class="bg-white border rounded-lg shadow hover:shadow-lg transition p-3">
      <!-- Thumbnail Slideshow -->
      <div class="relative w-full h-48 overflow-hidden rounded"
          data-controller="gallery-cycle">

        <% gallery.photos.each_with_index do |photo, i| %>
          <%= image_tag photo.image.variant(resize_to_limit: [400, 400]).processed,
                class: "absolute inset-0 w-full h-full object-cover transition-opacity duration-500 #{i == 0 ? 'opacity-100' : 'opacity-0'}",
                data: { gallery_cycle_target: "image" } %>
        <% end %>
      </div>

      <!-- Text Info -->
      <div class="mt-3 text-sm text-gray-700">
        <p class="font-semibold"><%= gallery.title %></p>
        <p class="text-gray-600"><%= gallery.description %></p>
        <p class="text-gray-500 italic">by <%= gallery.user.email %></p>
      </div>

      <!-- Link to gallery -->
      <%= link_to "View Gallery", gallery_path(gallery),
            class: "block mt-3 text-blue-600 hover:underline text-sm" %>
    </div>
  <% end %>
</div>